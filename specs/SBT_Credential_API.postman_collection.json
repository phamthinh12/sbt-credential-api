            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van B\",\n  \"email\": \"studentb@example.com\",\n  \"studentCode\": \"SV002\",\n  \"schoolId\": \"school_001\",\n  \"walletAddress\": \"0xabcdef1234567890abcdef1234567890abcdef12\"\n}"
            }
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/students/student_001",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A Updated\",\n  \"email\": \"updated@example.com\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/students/student_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Verify Student Created",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            }
          }
        }
      ]
    },
    {
      "name": "Schools",
      "item": [
        {
          "name": "Get All Schools",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/schools"
          }
        },
        {
          "name": "Get School By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/schools/school_001"
          }
        }
      ]
    },
    {
      "name": "Credentials",
      "item": [
        {
          "name": "Get All Credentials",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credentials",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Credential By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credentials/cred_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Verify by Code (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credentials/verify/CRED-20240115-ABC123"
          }
        },
        {
          "name": "Verify Credential Integrity by PDF",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/credentials/verify-file",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "verifyCode",
                  "value": "CRED-20240115-ABC123"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get Credentials by Student",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credentials/student/student_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Credentials by School",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/credentials/school/school_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Issue Credential",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/credentials",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"student_001\",\n  \"schoolId\": \"school_001\",\n  \"name\": \"Bachelor of Computer Science\",\n  \"description\": \"Completed 4-year program\",\n  \"issuerName\": \"University Admin\",\n  \"fileHash\": \"abc123def456\"\n}"
            }
          }
        },
        {
          "name": "Update Credential",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/credentials/cred_001",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Credential Name\",\n  \"status\": \"issued\"\n}"
            }
          }
        },
        {
          "name": "Confirm Credential",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/credentials/cred_001/confirm",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txHash\": \"0x1234567890abcdef\",\n  \"tokenId\": \"1\"\n}"
            }
          }
        },
        {
          "name": "Revoke Credential",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/credentials/cred_001/revoke",
            "header": [
