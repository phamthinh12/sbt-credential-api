{
  "info": {
    "name": "SBT Credential API",
    "description": "API for SBT Credential Management System\nBase URL: https://sbt-credential-api.onrender.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://sbt-credential-api.onrender.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Super Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login School Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"school_admin\",\n  \"password\": \"school123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Check Wallet",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/wallet/0x1234567890abcdef1234567890abcdef12345678"
          }
        }
      ]
    },
    {
      "name": "Registration Requests",
      "item": [
        {
          "name": "Create Registration Request",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/registration-requests",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"student\",\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"student1@example.com\",\n  \"password\": \"password123\",\n  \"schoolId\": \"school_001\",\n  \"studentCode\": \"SV001\"\n}"
            }
          }
        },
        {
          "name": "Create School Request",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/registration-requests",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"school\",\n  \"name\": \"Dai Hoc Cong Nghe\",\n  \"email\": \"admin@uni.edu.vn\",\n  \"password\": \"school123\",\n  \"schoolCode\": \"DHCN001\"\n}"
            }
          }
        },
        {
          "name": "Get All Requests (filter by type)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/registration-requests?type=student",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "registration-requests"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "student"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Requests by School",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/registration-requests?schoolId=school_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get School Requests",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/registration-requests?type=school",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Pending Requests",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/registration-requests/pending",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Request By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/registration-requests/req_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Approve Request",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/registration-requests/req_001/approve",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/registration-requests/req_001/reject",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Students by School",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students?schoolId=school_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Student By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students/student_001",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
